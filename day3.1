      "source": [
        "import numpy as np\n",
        "# Inputs\n",
        "inputs = np.array([1, 2, 3])\n",
        "# Weights\n",
        "weights = np.array([0.2, 0.8, -0.5])\n",
        "# Bias\n",
        "bias = 2\n",
        "# Output\n",
        "output = np.dot(inputs, weights) + bias\n",
        "print(\"Neuron Output:\", output)"
      ]
